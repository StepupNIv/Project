# ─── DevOps Practice App — Environment Variables ─────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_VERSION=1.0.0
LOG_LEVEL=info

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=devopsdb
DB_USER=appuser
DB_PASSWORD=apppassword

# ── Docker / Registry ─────────────────────────────────────────────────────────
REGISTRY=docker.io
REGISTRY_USER=youruser
APP_NAME=devops-practice-app
IMAGE_TAG=latest

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012
# For ECR: REGISTRY=${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com
S3_BUCKET=devops-mysql-backups

# ── Kubernetes ────────────────────────────────────────────────────────────────
KUBE_CONTEXT=arn:aws:eks:us-east-1:123456789012:cluster/my-cluster
K8S_NAMESPACE=production
HELM_RELEASE=devops-app

# ── Slack Notifications ───────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_CHANNEL=#devops-alerts
